# Copy the keys you need into your ESPHome secrets.yaml
# (Builder -> Secrets, i.e. /config/esphome/secrets.yaml). It is gitignored --
# never commit real values. Your device stub (see device.example.yaml) maps
# these secrets to the substitutions the firmware uses.

# --- Wi-Fi ---
wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"

# --- OTA upload password ---
# Set this to the SAME password your current firmware uses so wireless updates
# keep working without a USB re-flash. For a brand-new flash, pick any value;
# it becomes the OTA password after the first USB install.
ota_password: "choose-an-ota-password"

# --- Home Assistant native API encryption key (device appears in HA) ---
# Generate a fresh 32-byte base64 key, e.g. `openssl rand -base64 32`, or let the
# ESPHome dashboard generate one. Paste the SAME key into Home Assistant when it
# asks you to add the discovered device.
api_key: "PASTE_A_32_BYTE_BASE64_KEY_HERE="

# --- Static IP (ONLY if you enable the static-IP block in your device stub) ---
# DHCP is the default; the firmware ignores these unless your stub adds the
# manual_ip override (see device.example.yaml). Use your own LAN values.
static_ip: "192.168.1.50"
gateway: "192.168.1.1"
subnet: "255.255.255.0"
dns1: "1.1.1.1"
dns2: "1.0.0.1"
